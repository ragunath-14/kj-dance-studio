PORT=5001
MONGODB_URI=mongodb://localhost:27017/dance-studio
NODE_ENV=development
TZ=Asia/Kolkata

# Comma-separated list of allowed frontend origins (for CORS)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174

# Public-facing studio URL for payment portal links in WhatsApp messages
STUDIO_URL=http://localhost:5173

# Meta WhatsApp Cloud API Configuration
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_WABA_ID=
META_API_VERSION=v19.0

# Legacy WhatsApp API Configuration (alternative provider)
WHATSAPP_API_URL=
WHATSAPP_API_KEY=

# Scheduler Timing (Cron format) — Default: 09:00 AM daily
WHATSAPP_SCHEDULE_TIME="0 9 * * *"
