# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=production
TZ=Asia/Kolkata

# ─── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>

# ─── Security ─────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=change_this_to_a_strong_password
JWT_SECRET=change_this_to_a_long_random_secret_string

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# In production this is your domain (e.g. https://yourdomain.com)
ALLOWED_ORIGINS=https://yourdomain.com

# ─── Studio URL ───────────────────────────────────────────────────────────────
# Public-facing URL for payment portal links sent in WhatsApp messages
STUDIO_URL=https://yourdomain.com

# ─── WhatsApp / Meta Cloud API ────────────────────────────────────────────────
# Set USE_META_API=false to completely disable WhatsApp (safe while templates are pending)
USE_META_API=true

WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_WABA_ID=your_waba_id_here
WHATSAPP_VERSION=v19.0

# Webhook verification token (set this in Meta Developer Portal too)
WEBHOOK_VERIFY_TOKEN=choose_a_secret_token_string

# ─── Scheduler ────────────────────────────────────────────────────────────────
# Cron format: "minute hour day month weekday"
# Default: 9:00 AM every day IST
WHATSAPP_SCHEDULE_TIME=0 9 * * *
